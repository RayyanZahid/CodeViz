{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build:workers && concurrently -n server,client -c cyan,yellow \"pnpm --filter @archlens/server dev\" \"pnpm --filter @archlens/client dev\"",
    "build:workers": "pnpm --filter @archlens/server build:workers",
    "typecheck": "tsc -b packages/server packages/client"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "tree-sitter",
      "tree-sitter-typescript",
      "tree-sitter-javascript",
      "tree-sitter-python"
    ]
  }
}
